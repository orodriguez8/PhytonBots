# =============================================================================
# CREDENCIALES OANDA — .env
# =============================================================================
# 1. Copia este archivo y renómbralo a ".env"  (sin el .example)
# 2. Rellena los valores con tus credenciales de Oanda
# 3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
#
# Cómo obtener las credenciales:
#   A) Ve a https://www.oanda.com/demo-account/open-demo-account
#   B) Crea una cuenta demo gratuita
#   C) Entra en "My Services" → "Manage API Access"
#   D) Genera un Personal Access Token (tu OANDA_API_KEY)
#   E) En la plataforma, copia el ID de tu cuenta (tu OANDA_ACCOUNT_ID)
# =============================================================================

# Tu clave de API (Personal Access Token)
OANDA_API_KEY=pon_aqui_tu_api_key

# ID de tu cuenta Oanda (formato: 001-001-XXXXXXX-001)
OANDA_ACCOUNT_ID=pon_aqui_tu_account_id

# Entorno: 'practice' para cuenta DEMO | 'live' para cuenta REAL
OANDA_ENVIRONMENT=practice

# Par de divisas a operar
# Ejemplos: EUR_USD | GBP_USD | USD_JPY | XAU_USD (oro) | US30_USD (Dow Jones)
OANDA_INSTRUMENT=EUR_USD

# Temporalidad de las velas
# Opciones: M1 M5 M15 M30 H1 H2 H4 H8 D W M
OANDA_GRANULARITY=H1
